# ============================================================
# 1. FUNCIÓN PARA CARGAR EL DATASET DESDE CARPETAS
# ============================================================
def cargar_dataset(ruta_base, extractor):
    """
    Recorre carpetas de clases y extrae características.
    Estructura esperada:
        ruta_base/
            Clase_1/
                img1.jpg
                img2.jpg
            Clase_2/
                img3.jpg
    """
    X = []  # Características
    y = []  # Etiquetas (nombres de clase)
    
    clases = sorted(os.listdir(ruta_base))
    print(f"Clases detectadas: {clases}")
    
    for clase in clases:
        ruta_clase = os.path.join(ruta_base, clase)
        if not os.path.isdir(ruta_clase):
            continue
            
        archivos = [f for f in os.listdir(ruta_clase) 
                    if f.lower().endswith(('.png', '.jpg', '.jpeg'))]
        print(f"  Procesando {clase}: {len(archivos)} imágenes")
        
        for archivo in archivos:
            ruta_img = os.path.join(ruta_clase, archivo)
            img = cv2.imread(ruta_img)
            if img is None:
                continue
                
            features = extractor.extract(img)
            if np.sum(features) == 0 or np.isnan(features).any():
                continue
                
            X.append(features)
            y.append(clase)
    
    return np.array(X), np.array(y), sorted(list(set(y)))


# ============================================================
# 2. FUNCIÓN DE EVALUACIÓN COMPLETA (Requisitos del PDF)
# ============================================================
def evaluar_knn(X_train, y_train, X_test, y_test, clases, 
                usar_pca=False, n_components=15, k=5, 
                guardar_modelos=False, ruta_guardado="modelos_knn"):
    print(f"\n{'='*60}")
    print(f"  EVALUACIÓN KNN {'CON PCA' if usar_pca else 'SIN PCA'} (k={k})")
    print(f"{'='*60}")
    
    # --- ESCALADO (OBLIGATORIO PARA KNN) ---
    scaler = StandardScaler()
    X_train_scaled = scaler.fit_transform(X_train)
    X_test_scaled = scaler.transform(X_test)
    
    # --- REDUCCIÓN DIMENSIONAL (OPCIONAL) ---
    pca = None
    if usar_pca:
        pca = PCA(n_components=n_components)
        X_train_scaled = pca.fit_transform(X_train_scaled)
        X_test_scaled = pca.transform(X_test_scaled)
        print(f"PCA: {X_train.shape[1]} -> {n_components} componentes")
        print(f"Varianza explicada: {pca.explained_variance_ratio_.sum()*100:.2f}%")
    
    # --- ENTRENAMIENTO (Medir tiempo) ---
    knn = KNN(k=k)
    t0 = time.time()
    knn.fit(X_train_scaled, y_train)
    tiempo_entrenamiento = time.time() - t0
    print(f"Tiempo de entrenamiento: {tiempo_entrenamiento*1000:.4f} ms")
    
    # --- INFERENCIA (Medir tiempo) ---
    t0 = time.time()
    predicciones = knn.predict(X_test_scaled)
    tiempo_inferencia = time.time() - t0
    print(f"Tiempo de inferencia (todo el test): {tiempo_inferencia*1000:.2f} ms")
    print(f"Tiempo promedio por muestra: {tiempo_inferencia*1000/len(X_test):.4f} ms")
    
    # --- MÉTRICAS (Con labels para evitar errores) ---
    accuracy = accuracy_score(y_test, predicciones)
    f1_macro = f1_score(y_test, predicciones, average='macro', 
                        labels=clases, zero_division=0)
    print(f"\nPrecisión (Accuracy): {accuracy*100:.2f}%")
    print(f"F1 Score (macro): {f1_macro:.4f}")
    
    print("\nReporte de clasificación:")
    print(classification_report(
        y_test, predicciones, 
        labels=clases,           # 🔑 Lista completa de clases
        target_names=clases, 
        zero_division=0
    ))
    
    # --- MATRIZ DE CONFUSIÓN ---
    cm = confusion_matrix(y_test, predicciones, labels=clases)
    plt.figure(figsize=(8, 6))
    sns.heatmap(cm, annot=True, fmt='d', cmap='Blues', 
                xticklabels=clases, yticklabels=clases)
    titulo = f"Matriz de Confusión KNN {'(con PCA)' if usar_pca else '(sin PCA)'}"
    plt.title(titulo)
    plt.xlabel("Predicción")
    plt.ylabel("Real")
    plt.tight_layout()
    plt.show()
    
    # --- GUARDAR MODELOS (Opcional, para usar después en ventana deslizante) ---
    if guardar_modelos:
        os.makedirs(ruta_guardado, exist_ok=True)
        sufijo = "pca" if usar_pca else "sin_pca"
        joblib.dump(scaler, os.path.join(ruta_guardado, f"scaler_{sufijo}.pkl"))
        joblib.dump(knn, os.path.join(ruta_guardado, f"knn_{sufijo}.pkl"))
        if pca is not None:
            joblib.dump(pca, os.path.join(ruta_guardado, f"pca_{sufijo}.pkl"))
        print(f"\n✅ Modelos guardados en: {ruta_guardado}/")
    
    return {
        'knn': knn,
        'scaler': scaler,
        'pca': pca,
        'accuracy': accuracy,
        'f1': f1_macro,
        't_entrenamiento': tiempo_entrenamiento,
        't_inferencia': tiempo_inferencia
    }


